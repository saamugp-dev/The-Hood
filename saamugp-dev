        <a href="#shop" class="btn-hood">Explorar Catálogo</a>
      </div>
    </div>
  </div>
</section>

<div class="brands-section">
  <div class="container">
    <div class="brand-ticker">
      <div class="brand-name">Stüssy</div>
      <div class="brand-name">Supreme</div>
      <div class="brand-name">Nude Project</div>
      <div class="brand-name">Cold Culture</div>
      <div class="brand-name">Carhartt WIP</div>
