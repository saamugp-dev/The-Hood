<div class="offcanvas offcanvas-end" tabindex="-1" id="sidebarCart">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title"><i class="bi bi-bag-check me-2"></i>Tu Bolsa</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body d-flex flex-column justify-content-between">
    <div id="cartItemsContainer" style="overflow-y: auto; max-height: 70vh;">
      <p class="text-muted text-center py-5">Tu carrito está vacío.</p>
    </div>
    
    <div class="cart-footer">
      <div class="total-row">
        <span>Total:</span>
        <span id="cartTotalSum">0.00 €</span>
      </div>
      <button class="btn-hood w-100 py-3" onclick="alert('¡Redireccionando a pasarela de pago segura simulada!');">Tramitar Pedido</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // 1. Base de datos interna de los artículos solicitados
  const listaProductos = [
    { id: 1, marca: 'Supreme', titulo: 'Box Logo Hoodie', precio: 195.00, categoria: 'ropas', img: 'https://images.unsplash.com/photo-1556821840-3a63f95609a7?w=500&q=80' },
    { id: 2, marca: 'Stüssy', titulo: '8-Ball Graphic Tee', precio: 55.00, categoria: 'ropas', img: 'https://images.unsplash.com/photo-1521572267360-ee0c2909d518?w=500&q=80' },
    { id: 3, marca: 'Off-White', titulo: 'Out Of Office Sneaker', precio: 410.00, categoria: 'zapas', img: 'https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=500&q=80' },
    { id: 4, marca: 'Air Jordan', titulo: '1 Retro High OG Chicago', precio: 220.00, categoria: 'zapas', img: 'https://images.unsplash.com/photo-1556906781-9a412961c28c?w=500&q=80' },
    { id: 5, marca: 'Nude Project', titulo: 'Not Sorry Sweatshirt', precio: 89.00, categoria: 'ropas', img: 'https://images.unsplash.com/photo-1543163521-1bf539c55dd2?w=500&q=80' },
    { id: 6, marca: 'Cold Culture', titulo: 'Alpine Puffer Jacket', precio: 140.00, categoria: 'ropas', img: 'https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?w=500&q=80' },
    { id: 7, marca: 'Carhartt WIP', titulo: 'Cargo Aviation Pants', precio: 110.00, categoria: 'ropas', img: 'https://images.unsplash.com/photo-1517462964-21fdcec3f25b?w=500&q=80' },
    { id: 8, marca: 'Air Jordan', titulo: '4 Retro Military Blue', precio: 210.00, categoria: 'zapas', img: 'https://images.unsplash.com/photo-1597045566677-8cf032ed6634?w=500&q=80' }
  ];

  // Carrito de memoria dinámico
  let carrito = [];

  // 2. Renderizar catálogo inicial
  function renderProductos(productosAMostrar) {
    const contenedor = document.getElementById('contenedor-productos');
    contenedor.innerHTML = '';
    
    productosAMostrar.forEach(p => {
      contenedor.innerHTML += `
        <div class="col">
          <div class="product-card">
            <div class="img-container">
              <span class="brand-badge">${p.marca}</span>
              <img src="${p.img}" alt="${p.titulo}">
            </div>
            <div class="product-info">
              <div class="product-title">${p.titulo}</div>
              <div class="product-category">${p.categoria === 'ropas' ? 'Prenda' : 'Sneakers'}</div>
              <div class="price-row">
                <div class="product-price">${p.precio.toFixed(2)} €</div>
                <button class="btn-add-cart" onclick="insertarAlCarrito(${p.id})">
                  <i class="bi bi-plus-lg"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      `;
    });
  }

  // 3. Sistema de filtros
  function filtrarProductos(categoria, totalBtn) {
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    totalBtn.classList.add('active');

    if(categoria === 'all') {
      renderProductos(listaProductos);
    } else {
      const filtrados = listaProductos.filter(p => p.categoria === categoria);
      renderProductos(filtrados);
    }
  }

  // 4. Agregar productos al carrito (Lógica JavaScript real)
  function insertarAlCarrito(id) {
    const articulo = listaProductos.find(p => p.id === id);
    carrito.push(articulo);
    actualizarCarritoUI();
    
    // Abrir el carrito automáticamente para dar feedback dinámico
    const miSidebar = new bootstrap.Offcanvas(document.getElementById('sidebarCart'));
    miSidebar.show();
  }

  // 5. Eliminar productos de la bolsa
  function quitarDelCarrito(indice) {
    carrito.splice(indice, 1);
    actualizarCarritoUI();
  }

  // 6. Sincronizar y redibujar interfaz del carrito
  function actualizarCarritoUI() {
    // Actualizar badges
    document.getElementById('cartCount').innerText = carrito.length;
    
    const contenedorArticulos = document.getElementById('cartItemsContainer');
    const campoTotal = document.getElementById('cartTotalSum');
    
    if(carrito.length === 0) {
      contenedorArticulos.innerHTML = '<p class="text-muted text-center py-5">Tu bolsa está vacía.</p>';
      campoTotal.innerText = '0.00 €';
      return;
    }
    
    contenedorArticulos.innerHTML = '';
    let sumaPrecios = 0;
    
    carrito.forEach((item, index) => {
      sumaPrecios += item.precio;
      contenedorArticulos.innerHTML += `
        <div class="cart-item">
          <img src="${item.img}" class="cart-item-img" alt="${item.titulo}">
          <div class="cart-item-info">
            <p class="cart-item-title">${item.marca} - ${item.titulo}</p>
            <span class="cart-item-price">${item.precio.toFixed(2)} €</span>
          </div>
          <button class="btn-remove" onclick="quitarDelCarrito(${index})">
            <i class="bi bi-trash3"></i>
          </button>
        </div>
      `;
    });
    
    campoTotal.innerText = sumaPrecios.toFixed(2) + ' €';
  }

  // Lanzar catálogo al iniciar la carga
  window.onload = () => {
    renderProductos(listaProductos);
  };
</script>

</body>
</html>
