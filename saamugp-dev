<section id="shop" class="py-5">
  <div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-3">
      <div>
        <h2 class="font-urban fw-bold text-uppercase m-0" style="letter-spacing:-0.02em;">Nuevas Existencias</h2>
        <p class="text-muted small m-0 mt-1">Filtrado por disponibilidad inmediata</p>
      </div>
      <div class="d-flex gap-2">
        <button class="filter-btn active" onclick="filtrarProductos('all', this)">Todos</button>
        <button class="filter-btn" onclick="filtrarProductos('ropas', this)">Prendas</button>
        <button class="filter-btn" onclick="filtrarProductos('zapas', this)">Zapatillas</button>
