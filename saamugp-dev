<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>THE HOOD · Streetwear & Sneakers</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

  <style>
    /* ── Variables de Estilo Hypebeast ── */
    :root {
      --bg-black:  #000000;
      --bg-dark:   #0B0B0B;
      --card-bg:   #121212;
      --accent:    #FF2A2A; /* Rojo Hype */
      --text-white:#FFFFFF;
      --text-gray: #888888;
      --font-urban: 'Space Grotesk', sans-serif;
      --font-body:  'Inter', sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--text-white); background: var(--bg-black); overflow-x: hidden; }

    /* ── Navbar Estilo Minimal Premium ── */
    .navbar {
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid #1A1A1A;
      padding: 1.2rem 0;
      position: fixed;
      width: 100%;
      top: 0;
      z-index: 1000;
    }
    .navbar-brand {
      font-family: var(--font-urban);
      font-weight: 700;
      font-size: 1.6rem;
      letter-spacing: -0.05em;
      color: var(--text-white) !important;
      text-transform: uppercase;
    }
    .navbar-brand span {
      background: var(--accent);
      color: #000;
      padding: 0.1rem 0.4rem;
      margin-left: 0.2rem;
      font-weight: 700;
    }
    .nav-link {
      color: var(--text-gray) !important;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 600;
      transition: color 0.2s;
    }
    .nav-link:hover, .nav-link.active { color: var(--text-white) !important; }
    .cart-icon-btn {
      position: relative;
      background: transparent;
      border: none;
      color: var(--text-white);
      font-size: 1.3rem;
      cursor: pointer;
    }
    .cart-badge {
      position: absolute;
      top: -5px;
      right: -8px;
      background: var(--accent);
      color: #fff;
      font-size: 0.65rem;
      padding: 0.2rem 0.4rem;
      border-radius: 50%;
      font-family: var(--font-urban);
    }

    /* ── Hero Brutalista ── */
    #hero {
      min-height: 90vh;
      background: 
        linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.8) 100%),
        url('https://images.unsplash.com/photo-1552374196-1ab2a1c593e8?w=1600&q=80') center/cover no-repeat;
      display: flex;
      align-items: center;
      padding-top: 5rem;
    }
    .hero-title {
      font-family: var(--font-urban);
      font-size: clamp(3.5rem, 9vw, 6.5rem);
      font-weight: 700;
      line-height: 0.9;
      letter-spacing: -0.04em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .hero-title span { color: var(--accent); }
    .hero-subtitle {
      font-size: 1.05rem;
      color: var(--text-gray);
      max-width: 500px;
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }
    .btn-hood {
      background: var(--text-white);
      color: var(--bg-black);
      font-family: var(--font-urban);
      font-weight: 700;
      text-transform: uppercase;
      padding: 1rem 2.5rem;
      border-radius: 0;
      border: none;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-block;
    }
    .btn-hood:hover {
      background: var(--accent);
      color: var(--text-white);
      transform: translateY(-2px);
    }

    /* ── Marcas Carousel / Grid ── */
    .brands-section {
      background: var(--bg-dark);
      border-bottom: 1px solid #1A1A1A;
      padding: 2rem 0;
      overflow: hidden;
    }
    .brand-ticker {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .brand-name {
      font-family: var(--font-urban);
      font-size: 1.1rem;
      font-weight: 700;
      text-transform: uppercase;
      color: #333;
      letter-spacing: 0.1em;
      transition: color 0.3s;
    }
    .brand-name:hover { color: var(--text-white); }

    /* ── Filtros de Catálogo ── */
    .filter-btn {
      background: transparent;
      border: 1px solid #222;
      color: var(--text-gray);
      font-family: var(--font-urban);
      text-transform: uppercase;
      font-size: 0.8rem;
      padding: 0.5rem 1.5rem;
      border-radius: 0;
      transition: all 0.3s;
    }
    .filter-btn:hover, .filter-btn.active {
      border-color: var(--text-white);
      color: var(--text-white);
      background: #111;
    }

    /* ── Tarjetas de Producto Elásticas (2 columnas en móvil) ── */
    .product-card {
      background: var(--card-bg);
      border: 1px solid #1A1A1A;
      position: relative;
      transition: all 0.3s ease;
      margin-bottom: 1rem;
    }
    .product-card:hover {
      border-color: #333;
      transform: translateY(-4px);
    }
    .img-container {
      position: relative;
      width: 100%;
      height: 280px;
      overflow: hidden;
      background: #181818;
    }
    .img-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .product-card:hover .img-container img {
      transform: scale(1.05);
    }
    .brand-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      background: rgba(0, 0, 0, 0.8);
      color: var(--text-white);
      font-family: var(--font-urban);
      font-size: 0.65rem;
      text-transform: uppercase;
      padding: 0.2rem 0.5rem;
      font-weight: 700;
      letter-spacing: 0.05em;
    }
    .product-info {
      padding: 1rem;
    }
    .product-title {
      font-family: var(--font-urban);
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 0.2rem;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .product-category {
      font-size: 0.75rem;
      color: var(--text-gray);
      margin-bottom: 0.6rem;
    }
    .price-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .product-price {
      font-family: var(--font-urban);
      font-weight: 700;
      font-size: 1.05rem;
    }
    .btn-add-cart {
      background: var(--text-white);
      color: var(--bg-black);
      border: none;
      width: 34px;
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-add-cart:hover {
      background: var(--accent);
      color: var(--text-white);
    }

    @media (max-width: 576px) {
      .img-container { height: 190px; } /* Altura optimizada para cuadrícula doble en iPhone */
    }

    /* ── Carrito Desplegable Deslizante (Offcanvas) ── */
    .offcanvas {
      background: var(--bg-dark);
      border-left: 1px solid #1A1A1A;
      color: var(--text-white);
    }
    .offcanvas-header {
      border-bottom: 1px solid #1A1A1A;
    }
    .offcanvas-title {
      font-family: var(--font-urban);
      font-weight: 700;
      text-transform: uppercase;
    }
    .btn-close-white { filter: invert(1); }
    .cart-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid #151515;
    }
    .cart-item-img {
      width: 60px;
      height: 60px;
      object-fit: cover;
      background: #181818;
    }
    .cart-item-info { flex-grow: 1; }
    .cart-item-title {
      font-family: var(--font-urban);
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      margin: 0;
    }
    .cart-item-price {
      font-size: 0.85rem;
      color: var(--accent);
      font-weight: 600;
    }
    .btn-remove {
      background: transparent;
      border: none;
      color: var(--text-gray);
      cursor: pointer;
      font-size: 0.9rem;
    }
    .btn-remove:hover { color: var(--accent); }
    .cart-footer {
      border-top: 1px solid #1A1A1A;
      padding-top: 1.5rem;
    }
    .total-row {
      display: flex;
      justify-content: space-between;
      font-family: var(--font-urban);
      font-weight: 700;
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }

    /* ── Banner de Drop Especial ── */
    .banner-drop {
      background: linear-gradient(135deg, #111 0%, #000 100%);
      border-top: 1px solid #1A1A1A;
      border-bottom: 1px solid #1A1A1A;
      padding: 6rem 0;
      text-align: center;
      position: relative;
    }
    .banner-title {
      font-family: var(--font-urban);
      font-weight: 700;
      font-size: clamp(2rem, 6vw, 4rem);
      letter-spacing: -0.03em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .banner-title span { color: var(--accent); }

    /* ── Footer Pro ── */
    footer {
      background: #000;
      color: var(--text-gray);
      padding: 4rem 0 2rem;
      font-size: 0.85rem;
      border-top: 1px solid #1A1A1A;
    }
    footer h5 {
      font-family: var(--font-urban);
      color: var(--text-white);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.9rem;
      margin-bottom: 1.2rem;
      letter-spacing: 0.05em;
    }
    footer a { color: var(--text-gray); text-decoration: none; transition: color 0.2s; }
    footer a:hover { color: var(--text-white); }
    .social-icons a {
      font-size: 1.2rem;
      color: var(--text-white);
      margin-right: 1rem;
    }
    .input-hood {
      background: #0B0B0B;
      border: 1px solid #222;
      color: #fff;
      border-radius: 0;
      padding: 0.6rem 1rem;
    }
    .input-hood:focus {
      background: #111;
      border-color: var(--accent);
      box-shadow: none;
      color: #fff;
    }
  </style>
</head>
<body>

<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="#">THE HOOD<span>DROP</span></a>
    
    <div class="d-flex align-items-center order-lg-3 gap-3">
      <button class="cart-icon-btn" data-bs-toggle="offcanvas" data-bs-target="#sidebarCart">
        <i class="bi bi-bag"></i>
        <span id="cartCount" class="cart-badge">0</span>
      </button>
      <button class="navbar-toggler border-0 text-white p-0 ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
